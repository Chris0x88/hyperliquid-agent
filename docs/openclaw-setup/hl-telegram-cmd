#!/usr/bin/env python3
"""Execute HyperLiquid Telegram commands as fixed code.

Called by OpenClaw skills via command-dispatch: tool.
Outputs text that OpenClaw sends back to the chat.

Usage: hl-telegram-cmd <command> [args...]
"""
import sys
import os
import json
import subprocess
from datetime import datetime, timezone
from pathlib import Path

# Ensure project root
PROJECT_ROOT = str(Path(__file__).resolve().parent.parent.parent)
sys.path.insert(0, PROJECT_ROOT)
os.chdir(PROJECT_ROOT)

import requests

HL_API = "https://api.hyperliquid.xyz/info"
MAIN_ADDR = "0x80B5801ce295C4D469F4C0C2e7E17bd84dF0F205"
VAULT_ADDR = "0x9da9a9aef5a968277b5ea66c6a0df7add49d98da"

WATCHLIST = [
    ("BTC", "BTC", ["btc", "bitcoin"], "crypto"),
    ("ETH", "ETH", ["eth", "ethereum"], "crypto"),
    ("Brent Oil", "xyz:BRENTOIL", ["oil", "brent", "brentoil"], "commodity"),
    ("WTI Crude", "xyz:CL", ["wti", "cl"], "commodity"),
    ("Gold", "xyz:GOLD", ["gold", "xau"], "commodity"),
    ("Silver", "xyz:SILVER", ["silver", "xag"], "commodity"),
    ("Nat Gas", "xyz:NATGAS", ["natgas", "gas"], "commodity"),
    ("S&P 500", "xyz:SP500", ["sp500", "spx"], "index"),
    ("Nvidia", "xyz:NVDA", ["nvda", "nvidia"], "equity"),
    ("Tesla", "xyz:TSLA", ["tsla", "tesla"], "equity"),
]

COIN_ALIASES = {}
for _name, _coin, _aliases, _cat in WATCHLIST:
    COIN_ALIASES[_coin.lower()] = _coin
    COIN_ALIASES[_name.lower()] = _coin
    for a in _aliases:
        COIN_ALIASES[a.lower()] = _coin


def _hl(payload):
    try:
        return requests.post(HL_API, json=payload, timeout=10).json()
    except:
        return {}


def cmd_status():
    now = datetime.now(timezone.utc)
    lines = [f"Portfolio ({now.strftime('%a %H:%M UTC')})", ""]

    spot = _hl({"type": "spotClearinghouseState", "user": MAIN_ADDR})
    for b in spot.get("balances", []):
        total = float(b.get("total", 0))
        if total > 0.01:
            coin = b["coin"]
            lines.append(f"  {coin}: ${total:,.2f}" if coin == "USDC" else f"  {coin}: {total:.4f}")

    perps = _hl({"type": "clearinghouseState", "user": MAIN_ADDR})
    for p in perps.get("assetPositions", []):
        pos = p["position"]
        lines.append(f"  {pos['coin']}: {pos['szi']} @ ${pos['entryPx']} | uPnL: ${pos['unrealizedPnl']}")

    orders = _hl({"type": "openOrders", "user": MAIN_ADDR})
    if orders:
        lines.append(f"\nORDERS ({len(orders)}):")
        for o in orders:
            side = "BUY" if o.get("side") == "B" else "SELL"
            lines.append(f"  {side} {o['sz']} {o['coin']} @ ${o['limitPx']}")

    vault = _hl({"type": "clearinghouseState", "user": VAULT_ADDR})
    vmarg = vault.get("marginSummary", {})
    lines.append(f"\nVAULT: ${float(vmarg.get('accountValue', 0)):,.2f}")
    for p in vault.get("assetPositions", []):
        pos = p["position"]
        lines.append(f"  {pos['coin']}: {pos['szi']} @ ${pos['entryPx']} | uPnL: ${pos['unrealizedPnl']}")

    weekday = now.weekday()
    hour = now.hour
    if weekday >= 5 and (hour >= 22 or hour < 6):
        regime = "DANGEROUS"
    elif weekday >= 5:
        regime = "WEEKEND"
    elif hour >= 22 or hour < 6:
        regime = "LOW"
    else:
        regime = "NORMAL"
    lines.append(f"\nLiquidity: {regime}")
    return "\n".join(lines)


def cmd_price():
    mids = _hl({"type": "allMids"})
    lines = ["Prices:"]
    for name, coin, aliases, cat in WATCHLIST:
        if coin in mids:
            lines.append(f"  {name}: ${float(mids[coin]):,.2f}")
        else:
            try:
                book = _hl({"type": "l2Book", "coin": coin})
                levels = book.get("levels", [])
                if len(levels) >= 2 and levels[0] and levels[1]:
                    mid = (float(levels[0][0]["px"]) + float(levels[1][0]["px"])) / 2
                    lines.append(f"  {name}: ${mid:,.2f}")
                else:
                    lines.append(f"  {name}: --")
            except:
                lines.append(f"  {name}: --")
    return "\n".join(lines)


def cmd_orders():
    orders = _hl({"type": "openOrders", "user": MAIN_ADDR})
    if not orders:
        return "No open orders."
    lines = [f"Open Orders ({len(orders)}):"]
    for o in orders:
        side = "BUY" if o.get("side") == "B" else "SELL"
        lines.append(f"  {side} {o['sz']} {o['coin']} @ ${o['limitPx']}")
    return "\n".join(lines)


def cmd_pnl():
    perps = _hl({"type": "clearinghouseState", "user": MAIN_ADDR})
    vault = _hl({"type": "clearinghouseState", "user": VAULT_ADDR})
    lines = ["P&L Summary:"]
    main_val = float(perps.get("marginSummary", {}).get("accountValue", 0))
    for p in perps.get("assetPositions", []):
        pos = p["position"]
        lines.append(f"  Main {pos['coin']}: uPnL ${pos['unrealizedPnl']}")
    vault_val = float(vault.get("marginSummary", {}).get("accountValue", 0))
    for p in vault.get("assetPositions", []):
        pos = p["position"]
        lines.append(f"  Vault {pos['coin']}: uPnL ${pos['unrealizedPnl']}")
    lines.append(f"\nMain equity: ${main_val:,.2f}")
    lines.append(f"Vault equity: ${vault_val:,.2f}")
    lines.append(f"Total: ${main_val + vault_val:,.2f}")
    return "\n".join(lines)


def cmd_watchlist():
    mids = _hl({"type": "allMids"})
    lines = ["Watchlist:", ""]
    by_cat = {}
    for name, coin, aliases, cat in WATCHLIST:
        by_cat.setdefault(cat, []).append((name, coin, aliases))
    for cat, markets in by_cat.items():
        lines.append(f"{cat.upper()}")
        for name, coin, aliases in markets:
            price = None
            if coin in mids:
                price = float(mids[coin])
            else:
                try:
                    book = _hl({"type": "l2Book", "coin": coin})
                    levels = book.get("levels", [])
                    if len(levels) >= 2 and levels[0] and levels[1]:
                        price = (float(levels[0][0]["px"]) + float(levels[1][0]["px"])) / 2
                except:
                    pass
            px = f"${price:,.2f}" if price else "--"
            lines.append(f"  {name:<12} {px:>12}")
        lines.append("")
    return "\n".join(lines)


def cmd_chart(args):
    parts = args.split() if args else []
    if not parts:
        lines = ["Usage: /hchart <market> [hours]", "", "Markets:"]
        for name, coin, aliases, cat in WATCHLIST:
            hint = aliases[0] if aliases else coin
            lines.append(f"  {hint}  — {name}")
        return "\n".join(lines)

    coin_input = parts[0].lower()
    coin = COIN_ALIASES.get(coin_input)
    if not coin:
        return f"Unknown market: {parts[0]}\nTry /hchart to see markets."

    hours = 72
    if len(parts) > 1:
        try:
            hours = int(parts[1])
        except ValueError:
            pass

    display = next((w[0] for w in WATCHLIST if w[1] == coin), coin)

    # Generate chart
    from cli.chart_engine import ChartEngine
    engine = ChartEngine()
    path = engine.price_action(coin, hours=hours)

    # Send photo via Telegram API
    token = subprocess.run(
        ["security", "find-generic-password", "-s", "hl-agent-telegram", "-a", "bot_token", "-w"],
        capture_output=True, text=True
    ).stdout.strip()

    # We need the chat_id from OpenClaw context - but we don't have it here
    # Return the path for now, OpenClaw can display it
    return f"Chart saved: {path}\n{display} ({coin}) — {hours}h"


def cmd_help():
    return (
        "HyperLiquid Commands (instant, no AI tokens):\n"
        "  /hstatus    — portfolio\n"
        "  /hwatchlist — markets + prices\n"
        "  /hchart     — chart (/hchart oil 72)\n"
        "  /hpowerlaw  — BTC model\n"
        "  /hpnl       — profit & loss\n"
        "  /horders    — open orders\n"
        "  /hhelp      — this message\n"
        "\nFree text → AI agent"
    )


COMMANDS = {
    "status": cmd_status,
    "price": cmd_price,
    "orders": cmd_orders,
    "pnl": cmd_pnl,
    "watchlist": cmd_watchlist,
    "help": cmd_help,
}


if __name__ == "__main__":
    # Parse command from args or stdin
    if len(sys.argv) > 1:
        cmd = sys.argv[1].lower().lstrip("/").removeprefix("h")
        args = " ".join(sys.argv[2:]) if len(sys.argv) > 2 else ""
    else:
        # Read from stdin (OpenClaw passes JSON)
        raw = sys.stdin.read().strip() if not sys.stdin.isatty() else ""
        if raw:
            try:
                data = json.loads(raw)
                cmd = data.get("commandName", "").lower().lstrip("/").removeprefix("h")
                args = data.get("command", "")
            except json.JSONDecodeError:
                cmd = raw.lower().lstrip("/").removeprefix("h")
                args = ""
        else:
            cmd = "help"
            args = ""

    if cmd == "chart":
        print(cmd_chart(args))
    elif cmd in COMMANDS:
        print(COMMANDS[cmd]())
    else:
        print(f"Unknown command: {cmd}\n" + cmd_help())
