# HyperLiquid Agent — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — it's gitignored

# ──────────────────────────────────────────────
# Telegram Bot (required for Telegram interface)
# ──────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=your_chat_id_here

# ──────────────────────────────────────────────
# AI Agent (optional — enables AI co-pilot)
# ──────────────────────────────────────────────
# OpenRouter API key for AI model access
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# ──────────────────────────────────────────────
# HyperLiquid Keys
# ──────────────────────────────────────────────
# RECOMMENDED: Use the keystore instead of env vars:
#   python -m cli.main keys import
#
# Only use env vars for Docker/Railway deployments:
# HL_PRIVATE_KEY=0x_your_api_wallet_private_key
#
# NEVER use your main wallet key. Create an API wallet:
#   app.hyperliquid.xyz > Portfolio > API Wallets > Generate

# ──────────────────────────────────────────────
# Vault (optional — for vault trading)
# ──────────────────────────────────────────────
# HL_VAULT_ADDRESS=0x_your_vault_address

# ──────────────────────────────────────────────
# Network
# ──────────────────────────────────────────────
# Set to "true" for mainnet, leave unset for testnet
# HL_MAINNET=true
