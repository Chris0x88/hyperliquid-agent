#!/usr/bin/env bash
# pre-commit hook: block secrets, personal data, and sensitive files
# Three layers of defense: .gitignore → explicit staging → THIS HOOK

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

BLOCKED=0

# --- Layer 1: Block dangerous file paths ---
BLOCKED_PATHS=(
    "^data/"
    "^logs/"
    "^memory/"
    "^wallets/"
    "^\.ows/"
    "^\.env"
    "\.keystore$"
    "\.key$"
    "\.jsonl$"
    "\.db$"
    "credentials"
    "secrets"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# --- Allow-list: known-safe paths under otherwise-blocked directories ---
# Files matching any ALLOWED_PATHS pattern are removed from the check set
# BEFORE the block-list loop runs. These are paths that would otherwise hit
# BLOCKED_PATHS (e.g. ^data/) but are explicitly safe: config files with no
# secrets, directory placeholders (.gitkeep), etc. Layer 2 content scanning
# still runs on these files, so secrets would still be caught.
ALLOWED_PATHS=(
    "^data/config/[^/]+\.(json|yaml|yml)$"
    "^data/news/\.gitkeep$"
    "^data/supply/\.gitkeep$"
    "^data/research/\.gitkeep$"
)

CHECK_FILES="$STAGED_FILES"
for allow in "${ALLOWED_PATHS[@]}"; do
    CHECK_FILES=$(echo "$CHECK_FILES" | grep -Ev "$allow" || true)
done

for pattern in "${BLOCKED_PATHS[@]}"; do
    MATCHES=$(echo "$CHECK_FILES" | grep -E "$pattern" || true)
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}BLOCKED: Sensitive file path detected:${NC}"
        echo "$MATCHES" | while read -r f; do echo "  - $f"; done
        BLOCKED=1
    fi
done

# --- Layer 2: Scan staged content for secrets ---
# Get the actual diff content of staged files, excluding this hook itself
SCAN_FILES=$(echo "$STAGED_FILES" | grep -vE '(githooks/|\.git/hooks/)' || true)
if [ -z "$SCAN_FILES" ]; then
    DIFF_CONTENT=""
else
    DIFF_CONTENT=$(echo "$SCAN_FILES" | xargs -I{} git diff --cached -- {} 2>/dev/null || true)
fi

# Private keys (hex, 64 chars after 0x)
if echo "$DIFF_CONTENT" | grep -qEi '0x[0-9a-f]{64}'; then
    echo -e "${RED}BLOCKED: Possible private key detected (0x + 64 hex chars)${NC}"
    echo "$DIFF_CONTENT" | grep -nEi '0x[0-9a-f]{64}' | head -3
    BLOCKED=1
fi

# API keys (common patterns)
if echo "$DIFF_CONTENT" | grep -qEi '(sk-ant-|sk-[a-z0-9]{20,}|AIza[a-zA-Z0-9_-]{35}|ghp_[a-zA-Z0-9]{36}|gho_[a-zA-Z0-9]{36})'; then
    echo -e "${RED}BLOCKED: Possible API key detected${NC}"
    echo "$DIFF_CONTENT" | grep -nEi '(sk-ant-|sk-[a-z0-9]{20,}|AIza|ghp_|gho_)' | head -3
    BLOCKED=1
fi

# Mnemonic seed phrases (12+ word patterns that look like BIP39)
if echo "$DIFF_CONTENT" | grep -qEi '(abandon|ability|able|about|above|absent).*\b(word|seed|mnemonic|phrase|recovery)\b'; then
    echo -e "${RED}BLOCKED: Possible seed phrase detected${NC}"
    BLOCKED=1
fi

# Bare private key assignment
if echo "$DIFF_CONTENT" | grep -qEi '(private.?key|secret.?key|api.?key|password)\s*[=:]\s*["\x27][^\s]{8,}'; then
    # Exclude obvious placeholders
    if ! echo "$DIFF_CONTENT" | grep -qEi '(private.?key|secret.?key|api.?key|password)\s*[=:]\s*["\x27](0x\.\.\.|sk-ant-\.\.\.|your|example|placeholder|xxx|TODO)'; then
        echo -e "${YELLOW}WARNING: Possible hardcoded secret detected — review carefully${NC}"
        echo "$DIFF_CONTENT" | grep -nEi '(private.?key|secret.?key|api.?key|password)\s*[=:]' | head -3
        # Warning only, not blocked — too many false positives in docs/examples
    fi
fi

# --- Layer 3: Block personal Claude memory files ---
if echo "$STAGED_FILES" | grep -qE '\.claude/'; then
    echo -e "${RED}BLOCKED: Claude memory/config files should not be committed to this repo${NC}"
    echo "$STAGED_FILES" | grep -E '\.claude/' | while read -r f; do echo "  - $f"; done
    BLOCKED=1
fi

# --- Verdict ---
if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo -e "${RED}Commit rejected. Remove sensitive files/content and try again.${NC}"
    echo -e "${YELLOW}To bypass (emergency only): git commit --no-verify${NC}"
    exit 1
fi

exit 0
