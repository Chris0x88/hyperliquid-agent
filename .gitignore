__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# Environment
.env
.env.*
!.env.example
.venv/
env/

# Private data — NEVER commit
data/daemon/
data/daemon_test/
data/cli/
data/snapshots/
data/diagnostics/
data/reports/
data/backtest/
data/candles/
data/research/markets/*/charts/
data/research/markets/*/notes/
data/research/evaluations/
data/research/trades/
data/research/market_notes/
data/research/issues.jsonl
data/research/issues_summary.md
data/research/learnings.md
data/thesis/
data/btc_history_*.json
data/agent_memory/
data/memory/
data/feedback.jsonl
data/bugs.md
data/todos.jsonl
data/test_leak.txt
data/power_law/
*.jsonl

# User-maintained Brent rollover schedule (the iterator falls back to its
# DEFAULT_CALENDAR if missing). The rest of data/calendar/ ships with the repo
# (annual.json, quarterly.json, halving cycle, political cycle, etc.).
data/calendar/brent_rollover.json

# Brief command runtime state (last_brief_state.json + brief_log.md).
# Not the same as the strategies/ source directory at the repo root.
data/strategies/

# Runtime strategy state (regenerated by daemon)
data/strategy/
data/supply/state.json

# Logs and runtime state
logs/
# Negations must list every path under the ignored dir explicitly because
# gitignore won't re-include files inside an ignored parent dir via a
# single directory-level negation. Whitelist source files under the
# dashboard's logs page (it's a Next.js route, not log output).
!web/dashboard/src/app/logs
!web/dashboard/src/app/logs/**
state/
*.pid
*.db

# Secrets / wallets
*.keystore
*.key
.ows/
wallets/

# Agent memory (local only)
memory/
.claude/

# Plists have hardcoded local paths — use .example templates
plists/*.plist

# OpenClaw config has hardcoded local paths
openclaw.json

# Web dashboard build artifacts
web/dashboard/node_modules/
web/dashboard/.next/
web/docs/node_modules/
web/docs/dist/
web/docs/.astro/
web/.auth_token

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Test / build artifacts
.pytest_cache/
htmlcov/
.coverage
data/research/quarantine/
*.bak

# Obsidian per-user view settings — the vault at docs/vault/ is tracked,
# but graph layouts, theme, open-pane state, trash are personal
docs/vault/.obsidian/
docs/vault/.trash/
data/agent/
