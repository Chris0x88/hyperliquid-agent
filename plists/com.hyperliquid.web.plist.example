<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hyperliquid.web</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/cdi/Developer/HyperLiquid_Bot/agent-cli/scripts/start_web.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/cdi/Developer/HyperLiquid_Bot/agent-cli</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/cdi/Developer/HyperLiquid_Bot/agent-cli/logs/web_launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/cdi/Developer/HyperLiquid_Bot/agent-cli/logs/web_launchd_err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/cdi/.bun/bin:/Users/cdi/Developer/HyperLiquid_Bot/agent-cli/.venv/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/cdi</string>
    </dict>
</dict>
</plist>
