{
  "name": "hyperliquid-agent",
  "version": "1.0.0",
  "description": "Autonomous Hyperliquid trading agent -- strategies, APEX orchestrator, risk management",
  "workspace": ".",
  "mcp": [
    {
      "name": "hl-trading",
      "command": "$HOME/path/to/hyperliquid-agent/.venv/bin/python",
      "args": ["-m", "cli.main", "mcp", "serve"],
      "cwd": "$HOME/path/to/hyperliquid-agent",
      "env": {
        "PYTHONPATH": "$HOME/path/to/hyperliquid-agent"
      }
    }
  ],
  "files": {
    "agents": "AGENTS.md",
    "tools": "TOOLS.md",
    "bootstrap": "BOOTSTRAP.md",
    "soul": "SOUL.md"
  }
}
